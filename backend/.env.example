# Port the API server listens on. Render sets this automatically — leave
# unset in production and it will be picked up from the platform's own PORT.
PORT=5000

# Comma-separated list of allowed frontend origins for CORS, e.g.
# https://pip-app.vercel.app,https://pip-staging.vercel.app
# Leave unset in local dev to allow all origins (default behavior).
CORS_ORIGINS=

# Firebase Admin SDK service account credentials.
# Local dev: leave unset and instead place the downloaded service account
#   JSON file in backend/src/config/firebase/ (git-ignored, never committed).
# Production (Render, etc.): the JSON file cannot be deployed, so set this
#   to either the raw service account JSON or a base64-encoded copy of it.
FIREBASE_SERVICE_ACCOUNT=
